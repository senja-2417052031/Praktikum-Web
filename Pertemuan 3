<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form Kehadiran Praktikan</title>
</head>
<body>

<form action="submit.php" method="post">
        <fieldset>
            <legend>Form Kehadiran Praktikan</legend>
            <label for="name">Name:</label>
            <input type="text" id="'name" name="name" placeholder="Masukkan nama"><br></br>

            <label for="npm">NPM:</label>
            <input type="npm" id="npm" name="npm" placeholder="Masukkan NPM"><br></br>

            <label>Kelas</label>
            <input type="text" list="kelas" name="kelas" placeholder="Pilih kelas">

            <datalist id="kelas">
                <option value="A"></option>
                <option value="B"></option>
                <option value="SI"></option>
                <option value="MI"></option>   
            </datalist><br></br>

            <label for="date">Tanggal</label>
            <input type="date"><br></br>

            <label for="time">Waktu</label>
            <input type="time"><br></br>

            <input type="submit" value="submit">
        
        </fieldset> 
</body>
</html>
